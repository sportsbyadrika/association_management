# ------------------------------------------------------------------
# Habitract environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit .env.
# ------------------------------------------------------------------

APP_NAME="Habitract"
# APP_ENV: local | production
APP_ENV="local"
# APP_DEBUG: true only in local; false in production
APP_DEBUG=true
APP_URL="http://localhost:8000"
# APP_KEY: random 32+ char string used for signing
APP_KEY=

# Database. DB_CONNECTION may be mysql | sqlite (MySQL 8 in production).
DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_DATABASE="habitract"
DB_USERNAME="habitract"
DB_PASSWORD="habitract"
# For DB_CONNECTION=sqlite, set the path instead:
DB_SQLITE_PATH="storage/database.sqlite"

# Session / security
SESSION_NAME="habitract_session"
# Idle timeout (seconds) — 30 min
SESSION_IDLE_TIMEOUT=1800
# Absolute session lifetime (seconds) — 8 h
SESSION_ABSOLUTE_TIMEOUT=28800

# Mail (PHPMailer over SMTP) — used for password reset
MAIL_MAILER="smtp"
MAIL_HOST="smtp.mailtrap.io"
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
# MAIL_ENCRYPTION: tls | ssl | none
MAIL_ENCRYPTION="tls"
MAIL_FROM_ADDRESS="no-reply@habitract.local"
MAIL_FROM_NAME="Habitract"

# Seed super admin (created on first migration/seed run).
SUPER_ADMIN_NAME="Super Admin"
SUPER_ADMIN_EMAIL="admin@habitract.local"
SUPER_ADMIN_PASSWORD="ChangeMe!123"

# Login throttling
LOGIN_MAX_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15

# Password reset token lifetime (minutes)
RESET_TOKEN_TTL=60
